# ═══════════════════════════════════════════
# Smart Parking System — Git Ignore Rules
# ═══════════════════════════════════════════

# Python virtual environment (large, ~200MB, never commit)
venv/

# Python bytecode (auto-generated, not source code)
__pycache__/
*.pyc
*.pyo

# Database files (generated at runtime, not source code)
data/*.db

# Trained ML models (generated by training, not source code)
models/**/*.pkl

# pytest cache
.pytest_cache/

# OS files
Thumbs.db
.DS_Store

# IDE files
.vscode/
.idea/
*.swp
